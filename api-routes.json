{
  "api": {
    "name": "TaskFlow API",
    "version": "1.0",
    "baseUrl": "http://localhost:3000/api",
    "globalPrefix": "/api",
    "auth": {
      "type": "Bearer JWT",
      "headerKey": "Authorization",
      "defaultPolicy": "Toutes les routes sont protégées par JWT sauf si marquées publiques"
    },
    "enums": {
      "UserRole": {
        "ADMIN": "admin",
        "MEMBER": "member",
        "VIEWER": "viewer"
      },
      "ProjectStatus": {
        "DRAFT": "draft",
        "ACTIVE": "active",
        "ARCHIVED": "archived"
      },
      "TaskStatus": {
        "TODO": "todo",
        "IN_PROGRESS": "in_progress",
        "DONE": "done"
      },
      "TaskPriority": {
        "LOW": "low",
        "MEDIUM": "medium",
        "HIGH": "high"
      }
    },
    "endpoints": [
      {
        "category": "Santé API",
        "requests": [
          {
            "name": "Health check",
            "method": "GET",
            "path": "/health",
            "auth": "public",
            "description": "Vérifier que l'API est disponible",
            "response": {
              "status": 200,
              "example": {
                "status": "ok",
                "timestamp": "2026-04-29T10:00:00.000Z"
              }
            }
          },
          {
            "name": "Accueil API",
            "method": "GET",
            "path": "/",
            "auth": "bearer",
            "description": "Récupérer les infos de l'API",
            "response": {
              "status": 200,
              "example": {
                "message": "TaskFlow API",
                "version": "1.0"
              }
            }
          }
        ]
      },
      {
        "category": "Authentification",
        "requests": [
          {
            "name": "Login",
            "method": "POST",
            "path": "/auth/login",
            "auth": "public",
            "description": "Se connecter et obtenir un token JWT",
            "requestBody": {
              "required": ["email", "password"],
              "properties": {
                "email": {
                  "type": "string",
                  "format": "email",
                  "example": "alice@taskflow.dev"
                },
                "password": {
                  "type": "string",
                  "minLength": 8,
                  "example": "MotDePasse123"
                }
              }
            },
            "response": {
              "status": 200,
              "example": {
                "access_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                "user": {
                  "id": "20481b5c-62fb-43fa-9954-c87f3e158ada",
                  "email": "alice@taskflow.dev",
                  "name": "Alice Dupont",
                  "role": "admin"
                }
              }
            }
          },
          {
            "name": "Profil courant",
            "method": "GET",
            "path": "/auth/me",
            "auth": "bearer",
            "description": "Récupérer le profil de l'utilisateur connecté",
            "response": {
              "status": 200,
              "example": {
                "id": "20481b5c-62fb-43fa-9954-c87f3e158ada",
                "email": "alice@taskflow.dev",
                "name": "Alice Dupont",
                "role": "admin"
              }
            }
          }
        ]
      },
      {
        "category": "Utilisateurs",
        "requests": [
          {
            "name": "Créer utilisateur",
            "method": "POST",
            "path": "/users",
            "auth": "bearer",
            "rolesAllowed": ["admin"],
            "description": "Créer un nouvel utilisateur (ADMIN uniquement)",
            "requestBody": {
              "required": ["email", "name", "password"],
              "properties": {
                "email": {
                  "type": "string",
                  "format": "email",
                  "example": "bob@taskflow.dev"
                },
                "name": {
                  "type": "string",
                  "minLength": 2,
                  "maxLength": 100,
                  "example": "Bob Martin"
                },
                "password": {
                  "type": "string",
                  "minLength": 8,
                  "example": "MotDePasse123"
                },
                "role": {
                  "type": "string",
                  "enum": ["admin", "member", "viewer"],
                  "default": "member"
                }
              }
            },
            "response": {
              "status": 201,
              "example": {
                "id": "uuid",
                "email": "bob@taskflow.dev",
                "name": "Bob Martin",
                "role": "member",
                "createdAt": "2026-04-29T10:00:00.000Z"
              }
            }
          },
          {
            "name": "Lister utilisateurs",
            "method": "GET",
            "path": "/users",
            "auth": "bearer",
            "description": "Récupérer la liste de tous les utilisateurs",
            "response": {
              "status": 200,
              "example": [
                {
                  "id": "uuid",
                  "email": "alice@taskflow.dev",
                  "name": "Alice Dupont",
                  "role": "admin"
                }
              ]
            }
          },
          {
            "name": "Détail utilisateur",
            "method": "GET",
            "path": "/users/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid",
                "example": "20481b5c-62fb-43fa-9954-c87f3e158ada"
              }
            ],
            "response": {
              "status": 200
            }
          },
          {
            "name": "Modifier utilisateur",
            "method": "PATCH",
            "path": "/users/:id",
            "auth": "bearer",
            "rolesAllowed": ["admin", "self"],
            "description": "Modifier un utilisateur (ADMIN ou propriétaire du compte)",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "requestBody": {
              "required": [],
              "properties": {
                "email": {
                  "type": "string",
                  "format": "email"
                },
                "name": {
                  "type": "string",
                  "minLength": 2,
                  "maxLength": 100
                },
                "role": {
                  "type": "string",
                  "enum": ["admin", "member", "viewer"]
                }
              }
            },
            "response": {
              "status": 200
            }
          },
          {
            "name": "Supprimer utilisateur",
            "method": "DELETE",
            "path": "/users/:id",
            "auth": "bearer",
            "rolesAllowed": ["admin"],
            "description": "Supprimer un utilisateur (ADMIN uniquement)",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "response": {
              "status": 204
            }
          }
        ]
      },
      {
        "category": "Équipes",
        "requests": [
          {
            "name": "Créer équipe",
            "method": "POST",
            "path": "/teams",
            "auth": "bearer",
            "description": "Créer une nouvelle équipe",
            "requestBody": {
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "maxLength": 100,
                  "example": "Équipe Frontend"
                },
                "description": {
                  "type": "string",
                  "maxLength": 500,
                  "example": "Équipe en charge du développement front"
                }
              }
            },
            "response": {
              "status": 201,
              "example": {
                "id": "uuid",
                "name": "Équipe Frontend",
                "description": "Équipe en charge du développement front",
                "members": [],
                "createdAt": "2026-04-29T10:00:00.000Z"
              }
            }
          },
          {
            "name": "Lister équipes",
            "method": "GET",
            "path": "/teams",
            "auth": "bearer",
            "description": "Récupérer la liste de toutes les équipes",
            "response": {
              "status": 200
            }
          },
          {
            "name": "Détail équipe",
            "method": "GET",
            "path": "/teams/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "description": "Récupérer une équipe avec ses membres et projets",
            "response": {
              "status": 200
            }
          },
          {
            "name": "Modifier équipe",
            "method": "PATCH",
            "path": "/teams/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "requestBody": {
              "required": [],
              "properties": {
                "name": {
                  "type": "string",
                  "maxLength": 100
                },
                "description": {
                  "type": "string",
                  "maxLength": 500
                }
              }
            },
            "response": {
              "status": 200
            }
          },
          {
            "name": "Supprimer équipe",
            "method": "DELETE",
            "path": "/teams/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "response": {
              "status": 200
            }
          },
          {
            "name": "Ajouter membre à équipe",
            "method": "POST",
            "path": "/teams/:id/members",
            "auth": "bearer",
            "description": "Ajouter un utilisateur à une équipe",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "requestBody": {
              "required": ["userId"],
              "properties": {
                "userId": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "response": {
              "status": 201
            }
          },
          {
            "name": "Retirer membre d'équipe",
            "method": "DELETE",
            "path": "/teams/:id/members/:userId",
            "auth": "bearer",
            "description": "Supprimer un utilisateur d'une équipe",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              },
              {
                "name": "userId",
                "type": "uuid"
              }
            ],
            "response": {
              "status": 200
            }
          }
        ]
      },
      {
        "category": "Projets",
        "requests": [
          {
            "name": "Créer projet",
            "method": "POST",
            "path": "/projects",
            "auth": "bearer",
            "rolesAllowed": ["admin", "member"],
            "description": "Créer un nouveau projet (ADMIN ou MEMBER)",
            "requestBody": {
              "required": ["name"],
              "properties": {
                "name": {
                  "type": "string",
                  "maxLength": 200,
                  "example": "Refonte dashboard"
                },
                "description": {
                  "type": "string",
                  "maxLength": 1000,
                  "example": "Migration UI + perf"
                },
                "status": {
                  "type": "string",
                  "enum": ["draft", "active", "archived"],
                  "default": "draft"
                },
                "teamId": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "response": {
              "status": 201,
              "example": {
                "id": "uuid",
                "name": "Refonte dashboard",
                "description": "Migration UI + perf",
                "status": "draft",
                "team": null,
                "tasks": [],
                "createdAt": "2026-04-29T10:00:00.000Z"
              }
            }
          },
          {
            "name": "Lister projets",
            "method": "GET",
            "path": "/projects",
            "auth": "bearer",
            "description": "Récupérer la liste de tous les projets",
            "response": {
              "status": 200
            }
          },
          {
            "name": "Détail projet",
            "method": "GET",
            "path": "/projects/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "description": "Récupérer un projet avec ses tâches",
            "response": {
              "status": 200
            }
          },
          {
            "name": "Modifier projet",
            "method": "PATCH",
            "path": "/projects/:id",
            "auth": "bearer",
            "rolesAllowed": ["admin", "member"],
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "requestBody": {
              "required": [],
              "properties": {
                "name": {
                  "type": "string",
                  "maxLength": 200
                },
                "description": {
                  "type": "string",
                  "maxLength": 1000
                },
                "status": {
                  "type": "string",
                  "enum": ["draft", "active", "archived"]
                },
                "teamId": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "response": {
              "status": 200
            }
          },
          {
            "name": "Supprimer projet",
            "method": "DELETE",
            "path": "/projects/:id",
            "auth": "bearer",
            "rolesAllowed": ["admin"],
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "response": {
              "status": 200
            }
          }
        ]
      },
      {
        "category": "Tâches",
        "requests": [
          {
            "name": "Créer tâche",
            "method": "POST",
            "path": "/tasks",
            "auth": "bearer",
            "description": "Créer une nouvelle tâche",
            "requestBody": {
              "required": ["title", "projectId"],
              "properties": {
                "title": {
                  "type": "string",
                  "maxLength": 200,
                  "example": "Implémenter la page de login"
                },
                "description": {
                  "type": "string",
                  "maxLength": 2000,
                  "example": "Créer le formulaire avec validation"
                },
                "status": {
                  "type": "string",
                  "enum": ["todo", "in_progress", "done"],
                  "default": "todo"
                },
                "priority": {
                  "type": "string",
                  "enum": ["low", "medium", "high"],
                  "default": "medium"
                },
                "projectId": {
                  "type": "string",
                  "format": "uuid"
                },
                "assigneeId": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "response": {
              "status": 201,
              "example": {
                "id": "uuid",
                "title": "Implémenter la page de login",
                "description": "Créer le formulaire avec validation",
                "status": "todo",
                "priority": "high",
                "project": {},
                "assignee": null,
                "created_at": "2026-04-29T10:00:00.000Z"
              }
            }
          },
          {
            "name": "Lister tâches",
            "method": "GET",
            "path": "/tasks",
            "auth": "bearer",
            "description": "Récupérer la liste de toutes les tâches",
            "response": {
              "status": 200
            }
          },
          {
            "name": "Détail tâche",
            "method": "GET",
            "path": "/tasks/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "description": "Récupérer une tâche avec son projet et assigné",
            "response": {
              "status": 200
            }
          },
          {
            "name": "Modifier tâche",
            "method": "PATCH",
            "path": "/tasks/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "requestBody": {
              "required": [],
              "properties": {
                "title": {
                  "type": "string",
                  "maxLength": 200
                },
                "description": {
                  "type": "string",
                  "maxLength": 2000
                },
                "status": {
                  "type": "string",
                  "enum": ["todo", "in_progress", "done"]
                },
                "priority": {
                  "type": "string",
                  "enum": ["low", "medium", "high"]
                },
                "projectId": {
                  "type": "string",
                  "format": "uuid"
                },
                "assigneeId": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "response": {
              "status": 200
            }
          },
          {
            "name": "Supprimer tâche",
            "method": "DELETE",
            "path": "/tasks/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "response": {
              "status": 200
            }
          }
        ]
      },
      {
        "category": "Commentaires",
        "requests": [
          {
            "name": "Créer commentaire",
            "method": "POST",
            "path": "/comments",
            "auth": "bearer",
            "description": "Créer un nouveau commentaire sur une tâche",
            "requestBody": {
              "required": ["content", "taskId", "authorId"],
              "properties": {
                "content": {
                  "type": "string",
                  "maxLength": 1000,
                  "example": "Merci pour la mise a jour, je valide cette tache."
                },
                "taskId": {
                  "type": "string",
                  "format": "uuid"
                },
                "authorId": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "response": {
              "status": 201,
              "example": {
                "id": "uuid",
                "content": "Merci pour la mise a jour, je valide cette tache.",
                "author": {},
                "task": {},
                "created_at": "2026-04-29T10:00:00.000Z"
              }
            }
          },
          {
            "name": "Lister commentaires",
            "method": "GET",
            "path": "/comments",
            "auth": "bearer",
            "description": "Récupérer la liste de tous les commentaires",
            "response": {
              "status": 200
            }
          },
          {
            "name": "Détail commentaire",
            "method": "GET",
            "path": "/comments/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "description": "Récupérer un commentaire avec son auteur et sa tâche",
            "response": {
              "status": 200
            }
          },
          {
            "name": "Modifier commentaire",
            "method": "PATCH",
            "path": "/comments/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "requestBody": {
              "required": [],
              "properties": {
                "content": {
                  "type": "string",
                  "maxLength": 1000
                },
                "taskId": {
                  "type": "string",
                  "format": "uuid"
                },
                "authorId": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "response": {
              "status": 200
            }
          },
          {
            "name": "Supprimer commentaire",
            "method": "DELETE",
            "path": "/comments/:id",
            "auth": "bearer",
            "pathParams": [
              {
                "name": "id",
                "type": "uuid"
              }
            ],
            "response": {
              "status": 200
            }
          }
        ]
      }
    ]
  }
}
